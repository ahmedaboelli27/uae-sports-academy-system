generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PARENT
  COACH
  ACCOUNTANT
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum RecordStatus {
  ACTIVE
  INACTIVE
  TRIAL
  WITHDRAWN
  ON_LEAVE
  COMING_SOON
}

enum SportType {
  FOOTBALL
  BASKETBALL
  SWIMMING
  TENNIS
  MULTI_SPORT
  OTHER
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  PENDING
  CANCELLED
}

enum SubscriptionPlan {
  MONTHLY
  QUARTERLY
  ANNUAL
  CUSTOM
}

enum InvoiceStatus {
  DRAFT
  SENT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentStatus {
  PAID
  PENDING
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  ONLINE
  OTHER
}

enum TransactionType {
  SUBSCRIPTION_PAYMENT
  INVOICE_PAYMENT
  REFUND
  ADJUSTMENT
  OTHER
}

enum SessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum ContactMessageStatus {
  NEW
  READ
  REPLIED
  CLOSED
}

enum ContactMessagePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Role {
  id           String   @id
  code         UserRole @unique
  name         String
  label        String
  description  String
  permissions  Json
  redirectPath String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  users User[]

  @@map("roles")
}

model User {
  id           String       @id
  email        String       @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  roleId       String
  role         Role         @relation(fields: [roleId], references: [id])
  roleCode     UserRole
  locale       String       @default("en")
  status       RecordStatus @default(ACTIVE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  parent          Parent?
  coach           Coach?
  notifications   Notification[]
  auditLogs       AuditLog[]       @relation("AuditActor")
  contactMessages ContactMessage[]

  @@index([email])
  @@index([phone])
  @@index([roleCode])
  @@map("users")
}

model Parent {
  id               String       @id
  parentCode       String       @unique
  userId           String       @unique
  user             User         @relation(fields: [userId], references: [id])
  status           RecordStatus @default(ACTIVE)
  emergencyContact String?
  address          String?
  city             String?
  emirate          String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?

  students      Student[]
  subscriptions Subscription[]
  invoices      Invoice[]
  payments      Payment[]

  @@index([parentCode])
  @@map("parents")
}

model Student {
  id           String       @id
  studentCode  String       @unique
  parentId     String
  parent       Parent       @relation(fields: [parentId], references: [id])
  branchId     String?
  branch       Branch?      @relation(fields: [branchId], references: [id])
  programId    String?
  program      Program?     @relation(fields: [programId], references: [id])
  firstName    String
  lastName     String
  dateOfBirth  DateTime
  gender       Gender?
  status       RecordStatus @default(ACTIVE)
  medicalNotes String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  subscriptions     Subscription[]
  invoices          Invoice[]
  payments          Payment[]
  attendanceRecords AttendanceRecord[]
  enrollments       Enrollment[]

  @@index([studentCode])
  @@index([parentId])
  @@index([branchId])
  @@index([programId])
  @@map("students")
}

model Coach {
  id            String       @id
  coachCode     String       @unique
  userId        String       @unique
  user          User         @relation(fields: [userId], references: [id])
  status        RecordStatus @default(ACTIVE)
  bio           String?
  specialties   String[]
  licenseNumber String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  branchAssignments  CoachBranch[]
  programAssignments CoachProgram[]
  scheduleSessions   ScheduleSession[]

  @@index([coachCode])
  @@map("coaches")
}

model Branch {
  id         String       @id
  branchCode String      @unique
  name       String
  nameAr     String?
  city       String
  emirate    String
  address    String
  phone      String?
  email      String?
  status     RecordStatus @default(ACTIVE)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  deletedAt  DateTime?

  students         Student[]
  programs         ProgramBranch[]
  coachAssignments CoachBranch[]
  scheduleSessions ScheduleSession[]
  subscriptions    Subscription[]

  @@index([branchCode])
  @@map("branches")
}

model Sport {
  id        String       @id
  name      String
  nameAr    String?
  slug      String       @unique
  sportType SportType    @default(OTHER)
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?

  programs Program[]

  @@map("sports")
}

model Program {
  id           String       @id
  programCode  String       @unique
  sportId      String
  sport        Sport        @relation(fields: [sportId], references: [id])
  name         String
  nameAr       String?
  slug         String       @unique
  ageGroupMin  Int?
  ageGroupMax  Int?
  priceMonthly Decimal      @db.Decimal(12, 2)
  currency     String       @default("AED")
  capacity     Int          @default(20)
  description  String?
  status       RecordStatus @default(ACTIVE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  students         Student[]
  branches         ProgramBranch[]
  coachAssignments CoachProgram[]
  scheduleSessions ScheduleSession[]
  subscriptions    Subscription[]
  enrollments      Enrollment[]

  @@index([programCode])
  @@map("programs")
}

model ProgramBranch {
  id        String   @id @default(cuid())
  programId String
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([programId, branchId])
  @@map("program_branches")
}

model CoachBranch {
  id        String   @id @default(cuid())
  coachId   String
  coach     Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([coachId, branchId])
  @@map("coach_branches")
}

model CoachProgram {
  id        String   @id @default(cuid())
  coachId   String
  coach     Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  programId String
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([coachId, programId])
  @@map("coach_programs")
}

model Enrollment {
  id         String       @id
  studentId  String
  student    Student      @relation(fields: [studentId], references: [id])
  programId  String
  program    Program      @relation(fields: [programId], references: [id])
  branchId   String
  status     RecordStatus @default(ACTIVE)
  enrolledAt DateTime
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  deletedAt  DateTime?

  @@index([studentId])
  @@index([programId])
  @@map("enrollments")
}

model ScheduleSession {
  id        String        @id
  branchId  String
  branch    Branch        @relation(fields: [branchId], references: [id])
  programId String
  program   Program       @relation(fields: [programId], references: [id])
  coachId   String
  coach     Coach         @relation(fields: [coachId], references: [id])
  startAt   DateTime
  endAt     DateTime
  capacity  Int           @default(20)
  status    SessionStatus @default(SCHEDULED)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?

  attendanceRecords AttendanceRecord[]

  @@index([branchId])
  @@index([programId])
  @@index([coachId])
  @@index([startAt])
  @@map("schedule_sessions")
}

model AttendanceRecord {
  id               String           @id
  sessionId        String
  session          ScheduleSession  @relation(fields: [sessionId], references: [id])
  studentId        String
  student          Student          @relation(fields: [studentId], references: [id])
  status           AttendanceStatus
  recordedAt       DateTime
  recordedByUserId String?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  @@index([sessionId])
  @@index([studentId])
  @@map("attendance_records")
}

model Subscription {
  id               String             @id
  subscriptionCode String             @unique
  studentId        String
  student          Student            @relation(fields: [studentId], references: [id])
  parentId         String
  parent           Parent             @relation(fields: [parentId], references: [id])
  branchId         String
  branch           Branch             @relation(fields: [branchId], references: [id])
  programId        String
  program          Program            @relation(fields: [programId], references: [id])
  plan             SubscriptionPlan   @default(MONTHLY)
  status           SubscriptionStatus @default(PENDING)
  startDate        DateTime           @db.Date
  endDate          DateTime           @db.Date
  amount           Decimal            @db.Decimal(12, 2)
  currency         String             @default("AED")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?

  invoices Invoice[]
  payments Payment[]

  @@index([subscriptionCode])
  @@index([studentId])
  @@index([parentId])
  @@index([branchId])
  @@index([programId])
  @@map("subscriptions")
}

model Invoice {
  id             String        @id
  invoiceNumber  String        @unique
  parentId       String
  parent         Parent        @relation(fields: [parentId], references: [id])
  studentId      String?
  student        Student?      @relation(fields: [studentId], references: [id])
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  amount         Decimal       @db.Decimal(12, 2)
  currency       String        @default("AED")
  status         InvoiceStatus @default(DRAFT)
  dueDate        DateTime      @db.Date
  issuedAt       DateTime
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  lineItems InvoiceLineItem[]
  payments  Payment[]

  @@index([invoiceNumber])
  @@index([parentId])
  @@index([studentId])
  @@index([subscriptionId])
  @@map("invoices")
}

model InvoiceLineItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(12, 2)
  discount    Decimal  @default(0) @db.Decimal(12, 2)
  tax         Decimal  @default(0) @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([invoiceId])
  @@map("invoice_line_items")
}

model Payment {
  id              String          @id
  paymentCode     String          @unique
  parentId        String
  parent          Parent          @relation(fields: [parentId], references: [id])
  studentId       String?
  student         Student?        @relation(fields: [studentId], references: [id])
  invoiceId       String?
  invoice         Invoice?        @relation(fields: [invoiceId], references: [id])
  subscriptionId  String?
  subscription    Subscription?   @relation(fields: [subscriptionId], references: [id])
  amount          Decimal         @db.Decimal(12, 2)
  currency        String          @default("AED")
  status          PaymentStatus   @default(PENDING)
  method          PaymentMethod?
  transactionType TransactionType @default(SUBSCRIPTION_PAYMENT)
  paidAt          DateTime?
  reference       String?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  @@index([paymentCode])
  @@index([parentId])
  @@index([invoiceId])
  @@index([subscriptionId])
  @@map("payments")
}

model ContactMessage {
  id                     String                 @id @default(cuid())
  messageCode            String                 @unique
  userId                 String
  user                   User                   @relation(fields: [userId], references: [id])

  subject                String
  category               String                 @default("General")
  message                String
  preferredContactMethod String                 @default("Email")

  status                 ContactMessageStatus   @default(NEW)
  priority               ContactMessagePriority @default(NORMAL)

  adminReply             String?
  internalNote           String?

  readAt                 DateTime?
  repliedAt              DateTime?
  closedAt               DateTime?

  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  deletedAt              DateTime?

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@map("contact_messages")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id])
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  group     String   @default("general")
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([group])
  @@map("site_settings")
}